{
  "name": "mindless-route53",
  "version": "0.0.0-development",
  "description": "low-mental-load API/CLI for AWS Route 53",
  "bin": {
    "mindless-route53": "./dist/cli.js",
    "mroute53": "./dist/cli.js"
  },
  "sideEffects": false,
  "scripts": {
    "tc": "toolchain",
    "toolchain": "toolchain",
    "test": "toolchain test",
    "prepublishOnly": "echo This package is meant to be published by semantic-release from the dist build directory. && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jcoreio/mindless-route53.git"
  },
  "keywords": [
    "aws",
    "route53",
    "dns"
  ],
  "author": "Andy Edwards",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jcoreio/mindless-route53/issues"
  },
  "homepage": "https://github.com/jcoreio/mindless-route53#readme",
  "devDependencies": {
    "@babel/node": "^7.5.5",
    "@jcoreio/toolchain": "^5.10.4",
    "@jcoreio/toolchain-circle": "^5.10.4",
    "@jcoreio/toolchain-esnext": "^5.10.4",
    "@jcoreio/toolchain-mocha": "^5.10.4",
    "@jcoreio/toolchain-semantic-release": "^5.10.4",
    "@jcoreio/toolchain-typescript": "^5.10.4",
    "@types/chai": "^4.3.5",
    "@types/chai-as-promised": "^7.1.8",
    "@types/mocha": "^10.0.1",
    "@types/yargs": "^17",
    "chai": "^4.3.7",
    "chai-as-promised": "^7.1.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^8.3.0",
    "globals": "^16.0.0",
    "lint-staged": "^15.2.2",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.1.0"
  },
  "dependencies": {
    "@aws-sdk/client-route-53": "^3.988.0",
    "@babel/runtime": "^7.26.0",
    "@types/node": "^17.0.14",
    "deep-equal": "^2.0.3",
    "is-ip": "^3.1.0",
    "typed-validators": "^4.4.0",
    "yargs": "^17.7.2"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "default": "./dist/index.d.ts"
      },
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=16"
  },
  "packageManager": "pnpm@10.6.5",
  "@jcoreio/toolchain": {
    "migratedVersion": "5.10.4"
  }
}
